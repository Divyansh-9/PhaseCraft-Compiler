{
  "name": "compiler-visualizer",
  "version": "1.0.0",
  "description": "Compiler Visualizer - Frontend + Backend",
  "scripts": {
    "start": "concurrently --names \"API,VITE\" --prefix-colors \"cyan,magenta\" \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.js",
    "client": "cd client && npm run dev",
    "install-all": "cd server && npm install && cd ../client && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
